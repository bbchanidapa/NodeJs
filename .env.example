# Realtime Database — set ONE of the following (see Firebase Console → Realtime Database):
# Full URL (best if you use a regional *.firebasedatabase.app host):
# FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
#
# Or project id only — app will use https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
# FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# Server credentials (Firebase console → Project settings → Service accounts → Generate new private key)
# Option A: path to the downloaded JSON file
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Option B: instead of GOOGLE_APPLICATION_CREDENTIALS, set path only for this app
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Option C: single-line JSON (escape quotes if needed in your shell)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
